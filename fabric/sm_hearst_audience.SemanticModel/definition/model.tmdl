/// ─────────────────────────────────────────────────────────────────────────────
/// Hearst Digital Audience & Subscription Analytics - Direct Lake Semantic Model
/// ─────────────────────────────────────────────────────────────────────────────
/// This semantic model provides a unified star-schema view over three fact tables:
///   • fct_engagement (page views, sessions, time on page)
///   • fct_subscription (active/new/churned subscribers, MRR)
///   • fct_ad (impressions, clicks, ad revenue)
/// All facts share common dimensions: date, brand, content, subscriber, platform, campaign
///
/// IMPORTANT: Direct Lake source binding must be configured in Power BI Desktop or Fabric
/// to point to the lakehouse 'lh_hearst_gold' (SQL endpoint). The entityName references in
/// each table partition assume the gold.* schema in that lakehouse.
///
/// For deployment via Fabric REST API or XMLA endpoint, you may need to update the 
/// expression/source property with the actual workspace + lakehouse IDs or SQL endpoint
/// connection strings. See Microsoft Learn: "Direct Lake semantic models" for details.
/// ─────────────────────────────────────────────────────────────────────────────

model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	compatibilityLevel: 1605

	/// IMPORTANT: Direct Lake requires a lakehouse SQL endpoint connection.
	/// The expression below is a placeholder. In Power BI Desktop, use the 
	/// "Get Data > Lakehouse" connector and point to lh_hearst_gold (SQL endpoint).
	/// The actual connection ID and expression will be generated by Power BI Desktop.
	/// TODO: Update expression with your workspace-specific lakehouse SQL endpoint.
	/// Reference: https://learn.microsoft.com/fabric/onelake/onelake-open-lakehouse-direct-lake
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

/// ─────────────────────────────────────────────────────────────────────────────
/// Direct Lake shared source expression — referenced by EVERY table partition as
/// `expressionSource: 'DirectLake-lh_hearst_gold'`. Without this expression the
/// Direct Lake source is undefined and the model will not resolve.
/// TODO (finalize in Fabric): replace the SQL endpoint host below with your gold
/// lakehouse's SQL analytics endpoint (Fabric -> lh_hearst_gold -> Settings ->
/// SQL analytics endpoint). The database name is the lakehouse name. In Power BI
/// Desktop, binding via Get Data -> OneLake data hub -> lh_hearst_gold sets this
/// automatically. Ref: https://learn.microsoft.com/fabric/fundamentals/direct-lake-overview
/// ─────────────────────────────────────────────────────────────────────────────
expression 'DirectLake-lh_hearst_gold' =
		let
		    Source = Sql.Database("REPLACE-WITH-GOLD-SQL-ENDPOINT.datawarehouse.fabric.microsoft.com", "lh_hearst_gold")
		in
		    Source
	lineageTag: 00000000-0000-0000-0000-0000000000e1
	annotation PBI_ResultType = Table

