/// ─────────────────────────────────────────────────────────────────────────────
/// Star Schema Relationships: Dimensions filter Facts (single direction)
/// ─────────────────────────────────────────────────────────────────────────────
/// All relationships follow the standard star-schema pattern:
///   • Dimension (1) → Fact (*)
///   • Single direction (dimension filters fact)
///   • Cardinality: one-to-many
/// TODO: Verify lineageTags are unique if you encounter import errors in Power BI Desktop
/// ─────────────────────────────────────────────────────────────────────────────

/// ═════════════════════════════════════════════════════════════════════════════
/// ENGAGEMENT RELATIONSHIPS (fct_engagement)
/// ═════════════════════════════════════════════════════════════════════════════

relationship dim_date_to_fct_engagement
	fromColumn: dim_date.date_key
	toColumn: fct_engagement.date_key
	fromCardinality: one
	toCardinality: many
	crossFilteringBehavior: oneDirection
	lineageTag: 00000000-0000-0000-0000-000000000090

relationship dim_brand_to_fct_engagement
	fromColumn: dim_brand.brand_key
	toColumn: fct_engagement.brand_key
	fromCardinality: one
	toCardinality: many
	crossFilteringBehavior: oneDirection
	lineageTag: 00000000-0000-0000-0000-000000000091

relationship dim_content_to_fct_engagement
	fromColumn: dim_content.content_key
	toColumn: fct_engagement.content_key
