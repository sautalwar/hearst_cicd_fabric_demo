	toCardinality: many
	crossFilteringBehavior: oneDirection
	lineageTag: 00000000-0000-0000-0000-000000000092

relationship dim_subscriber_to_fct_engagement
	fromColumn: dim_subscriber.subscriber_key
	toColumn: fct_engagement.subscriber_key
	fromCardinality: one
	toCardinality: many
	crossFilteringBehavior: oneDirection
	lineageTag: 00000000-0000-0000-0000-000000000093

relationship dim_platform_to_fct_engagement
	fromColumn: dim_platform.platform_key
	toColumn: fct_engagement.platform_key
	fromCardinality: one
	toCardinality: many
	crossFilteringBehavior: oneDirection
	lineageTag: 00000000-0000-0000-0000-000000000094

